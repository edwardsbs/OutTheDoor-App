# Copy this file to ".env" (same directory as docker-compose.yml) and fill in
# the real values. docker compose loads ".env" automatically.
# Do NOT commit the real .env — it contains the database password.

# Connection string to the SQL Server LXC (CTID 101).
# Point Server= at the LXC host/IP; the "outthedoor" database is created
# automatically on first start (migrate-on-startup).
OTD_DB_CONNECTION=Server=192.168.0.XX,1433;Database=outthedoor;User Id=outthedoor_app;Password=CHANGE_ME;TrustServerCertificate=True

# Host port the web (nginx) container is published on. Defaults to 8081.
APP_PORT=8081
